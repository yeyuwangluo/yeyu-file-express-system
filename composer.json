{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "yeyu-file-express/system",
    "type": "project",
    "description": "Yeyu File Express upload, sharing, LAN transfer, and admin system.",
    "keywords": ["yeyu-file-express", "laravel", "file-sharing"],
    "license": "MIT",
    "require": {
        "php": "^8.0.2",
        "laravel/framework": "^9.52",
        "laravel/sanctum": "^3.3",
        "laravel/tinker": "^2.10",
        "league/flysystem-aws-s3-v3": "^3.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^6.4",
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "exclude-from-classmap": []
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php -d error_reporting=6143 artisan key:generate",
            "@php -d error_reporting=6143 artisan migrate --force"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "concurrently -c \"#93c5fd,#c4b5fd\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" --names=server,queue --kill-others"
        ],
        "test": [
            "@php -d error_reporting=6143 artisan config:clear --ansi",
            "@php -d error_reporting=6143 artisan test"
        ],
        "post-autoload-dump": [
            "@php -d error_reporting=6143 artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php -d error_reporting=6143 artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php -d error_reporting=6143 artisan migrate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        },
        "platform": {
            "php": "8.0.2"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
