APP_NAME=小鑫文件快递
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
XIAOXIN_FILE_EXPRESS_INSTALLED=

APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=zh_CN
APP_FAKER_LOCALE=zh_CN

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=xiaoxin_file_express
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_DRIVER=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_DRIVER=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false
STORAGE_LIMIT_BYTES=107374182400

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-immediately

UPLOAD_MAX_FILE_SIZE=52428800
UPLOAD_DEFAULT_EXPIRE_DAYS=1
UPLOAD_MAX_EXPIRE_DAYS=7
UPLOAD_ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp,avif,bmp,ico,livp,mp3,wav,flac,m4a,aac,ogg,opus,mp4,webm,mov,m4v,pdf,txt,md,json,csv,doc,docx,xls,xlsx,ppt,pptx,zip,rar,7z,tar,gz,apk

CHUNKED_UPLOAD_ENABLED=true
CHUNKED_UPLOAD_MAX_CHUNK_SIZE=10485760
CHUNKED_UPLOAD_MAX_CHUNKS=10000
CHUNKED_UPLOAD_TTL_MINUTES=120

RISK_BLOCK_SCORE=90
RISK_FAILURE_WINDOW_MINUTES=60
RISK_FAILURE_LIMIT=5

VIRUS_SCAN_ENABLED=false
CLAMAV_PATH=clamscan
VIRUS_SCAN_TIMEOUT_SECONDS=60

GEETEST_ENABLED=false
GEETEST_CAPTCHA_ID=

FOOTER_ICP_BEIAN=
FOOTER_GONGAN_BEIAN=
FOOTER_GONGAN_CODE=

LAN_TRANSFER_ENABLED=true
LAN_MAX_FILE_SIZE=2147483648
LAN_MAX_FILE_COUNT=5
LAN_MAX_TOTAL_SIZE_ENABLED=false
LAN_MAX_TOTAL_SIZE=21474836480
LAN_ALLOWED_FILE_TYPES=
LAN_EXPIRE_MINUTES=10
LAN_COMPLETED_RETENTION_MINUTES=860
LAN_TEXT_ENABLED=true
LAN_TEXT_MAX_LENGTH=15000
LAN_TEXT_MAX_LINES=500
LAN_TEXT_ALLOW_TITLE=true
LAN_TEXT_RETENTION_MINUTES=1440

VITE_APP_NAME="${APP_NAME}"
